{
  "name": "@x2zod/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Command-line interface for x2zod.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gkze/x2zod.git",
    "directory": "apps/cli"
  },
  "bin": {
    "x2zod": "./src/cli.ts"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "turbo run lint typecheck test --filter=@x2zod/cli",
    "lint": "bun --cwd ../.. oxlint apps/cli",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@x2zod/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "tsconfig": "workspace:*"
  }
}
