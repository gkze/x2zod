{
  "name": "@x2zod/json-schema",
  "version": "0.0.0",
  "description": "JSON Schema input plugin for x2zod.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/json-schema"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "turbo run lint typecheck test --filter=@x2zod/json-schema",
    "lint": "bun --cwd ../.. oxlint packages/json-schema",
    "test": "bun test --pass-with-no-tests --path-ignore-patterns test/opencode.e2e.test.ts && bun test --pass-with-no-tests test/opencode.e2e.test.ts",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@x2zod/core": "workspace:*",
    "ajv": "8.20.0",
    "jsonc-parser": "3.3.1",
    "type-fest": "5.7.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@x2zod/build-inputs": "workspace:*",
    "@x2zod/tsconfig": "workspace:*",
    "memfs": "4.57.6",
    "opencode-ai": "1.16.2"
  }
}
