{
  "name": "@x2zod/json-schema",
  "version": "0.1.1",
  "description": "JSON Schema input plugin for x2zod.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/json-schema"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "turbo run lint typecheck test --filter=@x2zod/json-schema",
    "lint": "bun --cwd ../.. oxlint packages/json-schema",
    "test": "bun test ./test --path-ignore-patterns test/opencode.e2e.test.ts && bun test ./test/opencode.e2e.test.ts",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@x2zod/core": "workspace:*",
    "ajv": "8.20.0",
    "jsonc-parser": "3.3.1",
    "type-fest": "5.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260612.1",
    "@x2zod/build-inputs": "workspace:*",
    "@x2zod/tsconfig": "workspace:*",
    "opencode-ai": "1.17.4"
  }
}
