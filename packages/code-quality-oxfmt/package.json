{
  "name": "@x2zod/code-quality-oxfmt",
  "version": "0.1.2",
  "description": "Oxfmt code quality plugin for x2zod.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/code-quality-oxfmt"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "turbo run lint typecheck test --filter=@x2zod/code-quality-oxfmt",
    "lint": "bun --cwd ../.. oxlint packages/code-quality-oxfmt",
    "test": "bun test ./test",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@x2zod/config": "workspace:*",
    "oxfmt": "0.54.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@x2zod/tsconfig": "workspace:*"
  }
}
