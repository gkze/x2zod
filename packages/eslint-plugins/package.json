{
  "name": "@x2zod/eslint-plugins",
  "version": "0.0.0",
  "description": "ESLint-compatible Oxlint plugins for x2zod code quality.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/eslint-plugins"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "imports": {
    "#index": "./src/index.ts",
    "#options": "./src/options.ts",
    "#rule": "./src/rule.ts",
    "#rules/*": "./src/rules/*.ts",
    "#source": "./src/source.ts",
    "#text": "./src/text.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "turbo run lint typecheck test --filter=@x2zod/eslint-plugins",
    "lint": "bun --cwd ../.. oxlint packages/eslint-plugins",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260612.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@x2zod/tsconfig": "workspace:*"
  }
}
