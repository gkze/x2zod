{
  "name": "@x2zod/core",
  "version": "0.0.0",
  "private": true,
  "description": "Core compiler contracts and TypeScript source construction for x2zod.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gkze/x2zod.git",
    "directory": "packages/core"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test",
    "lint": "cd ../.. && oxlint packages/core",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "tsconfig": "workspace:*"
  }
}
