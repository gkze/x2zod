{
  "name": "@x2zod/core",
  "version": "0.2.0",
  "description": "Core compiler contracts and TypeScript source construction for x2zod.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/core"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun --no-env-file run --cwd ../.. runtime:check && turbo run lint typecheck test --filter=@x2zod/core",
    "lint": "bun --no-env-file --cwd ../.. oxlint packages/core",
    "test": "bun --no-env-file test ./test",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@x2zod/tsconfig": "workspace:*"
  }
}
