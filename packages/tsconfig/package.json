{
  "name": "@x2zod/tsconfig",
  "version": "0.0.1",
  "description": "Shared TypeScript compiler configuration for x2zod packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/tsconfig"
  },
  "files": [
    "base.json"
  ],
  "type": "module",
  "exports": {
    "./base.json": "./base.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "../../node_modules/.bin/turbo run lint typecheck test --filter=@x2zod/tsconfig",
    "lint": "bun --eval \"void 0\"",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  }
}
