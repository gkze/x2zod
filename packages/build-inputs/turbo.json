      "inputs": [
        "package.json",
        "src/build-inputs.ts",
        "src/generate-build-inputs-schema.ts",
        "tsconfig.json"
      ],
      "outputs": ["schema/build-inputs.schema.json"]
    },
    "gen:check:schema": {
      "inputs": [
        "package.json",
        "schema/build-inputs.schema.json",
        "src/build-inputs.ts",
        "src/generate-build-inputs-schema.ts",
        "tsconfig.json"
      ],
      "outputs": []
    }
  }
}
