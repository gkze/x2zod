{
  "name": "@x2zod/build-inputs",
  "version": "0.1.1",
  "description": "Pinned external build input materialization for x2zod tests and fixtures.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git",
    "directory": "packages/build-inputs"
  },
  "bin": {
    "build-inputs": "bin/build-inputs.ts"
  },
  "files": [
    "bin",
    "schema",
    "src"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./build-inputs": {
      "types": "./src/build-inputs.ts",
      "default": "./src/build-inputs.ts"
    },
    "./directory-merkle-tree": {
      "types": "./src/directory-merkle-tree.ts",
      "default": "./src/directory-merkle-tree.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "turbo run lint typecheck gen:check test --filter=@x2zod/build-inputs",
    "gen": "bun run gen:schema",
    "gen:check": "bun run gen:check:schema",
    "gen:check:schema": "bun ./src/generate-build-inputs-schema.ts --check",
    "gen:schema": "bun ./src/generate-build-inputs-schema.ts",
    "lint": "bun --cwd ../.. oxlint packages/build-inputs",
    "test": "bun test ./src",
    "typecheck": "tsgo --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@optique/core": "1.0.2",
    "minimatch": "10.2.5",
    "p-limit": "7.3.0",
    "tar": "7.5.16",
    "ts-pattern": "5.9.0",
    "type-fest": "5.7.0",
    "yauzl": "3.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/yauzl": "3.3.0",
    "@x2zod/tsconfig": "workspace:*"
  }
}
