{
  "name": "x2zod-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Schema and IDL to Zod source compiler.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkze/x2zod.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "check": "bun --no-env-file run runtime:check && turbo run --concurrency=4 //#format:check:workspace //#format:check:shell //#format:check:toml //#lint:actions //#lint:hooks //#lint:markdown //#lint:repo //#lint:shell //#lint:suppressions //#lint:toml //#lockfile:check //#test:repo //#typecheck:configs gen:check lint typecheck test",
    "commitlint": "bun --no-env-file run runtime:check && commitlint",
    "format": "bun --no-env-file run runtime:check && turbo run //#format:workspace //#format:shell //#format:toml",
    "format:check": "bun --no-env-file run runtime:check && turbo run //#format:check:workspace //#format:check:shell //#format:check:toml",
    "format:check:shell": "bun --no-env-file scripts/shfmt.ts",
    "format:check:toml": "taplo fmt --check bunfig.toml prek.toml",
    "format:check:workspace": "oxfmt --check .",
    "format:shell": "bun --no-env-file scripts/shfmt.ts --write",
    "format:toml": "taplo fmt bunfig.toml prek.toml",
    "format:workspace": "oxfmt --write .",
    "hooks:install": "bun --no-env-file run runtime:check && bun --no-env-file scripts/install-hooks.ts",
    "hooks:run": "bun --no-env-file run runtime:check && prek run --all-files",
    "lint": "bun --no-env-file run runtime:check && turbo run --concurrency=4 //#lint:actions //#lint:hooks //#lint:markdown //#lint:repo //#lint:shell //#lint:suppressions //#lint:toml lint",
    "lint:actions": "bun --no-env-file scripts/check-native-tools.ts actionlint && find .github/workflows -type f \\( -name '*.yml' -o -name '*.yaml' \\) -print0 | xargs -0 \"$ACTIONLINT_BIN\" -shellcheck \"$SHELLCHECK_BINARY\"",
    "lint:fix": "bun --no-env-file run oxlint --fix .",
    "lint:hooks": "prek validate-config prek.toml",
    "lint:markdown": "markdownlint-cli2",
    "lint:repo": "bun --no-env-file run oxlint .markdownlint-cli2.mjs commitlint.config.ts scripts test",
    "lint:shell": "bun --no-env-file scripts/check-native-tools.ts shellcheck && \"$SHELLCHECK_BINARY\" .envrc",
    "lint:suppressions": "bun --no-env-file scripts/check-no-suppressions.ts",
    "lint:toml": "taplo lint bunfig.toml prek.toml",
    "lockfile:check": "bun --no-env-file run runtime:check && bun --no-env-file install --frozen-lockfile --lockfile-only --ignore-scripts",
    "oxlint": "\"${X2ZOD_NODE_BINARY:-node}\" node_modules/.bin/oxlint --format default --threads=1",
    "preinstall": "bun --no-env-file scripts/check-runtime-versions.ts",
    "prepare": "bun --no-env-file run hooks:install",
    "publish:jsr": "bun --no-env-file scripts/publish.ts jsr",
    "publish:npm": "bun --no-env-file scripts/publish.ts npm",
    "publish:packages": "bun --no-env-file scripts/publish.ts",
    "release:version": "changeset version && bun --no-env-file scripts/publish.ts --sync-jsr-metadata && bun --no-env-file install",
    "runtime:check": "bun --no-env-file scripts/check-runtime-versions.ts",
    "test": "bun --no-env-file run runtime:check && turbo run --concurrency=4 test",
    "test:repo": "bun --no-env-file test ./scripts",
    "typecheck": "bun --no-env-file run runtime:check && turbo run --concurrency=4 //#typecheck:configs typecheck",
    "typecheck:configs": "tsgo --project tsconfig.configs.json --noEmit",
    "x2zod": "x2zod"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@changesets/config": "3.1.4",
    "@changesets/pre": "2.0.2",
    "@changesets/should-skip-package": "0.1.2",
    "@changesets/types": "6.1.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@j178/prek": "0.4.4",
    "@manypkg/get-packages": "3.1.0",
    "@optique/core": "1.0.2",
    "@optique/run": "1.0.2",
    "@taplo/cli": "0.7.0",
    "@types/node": "24.13.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@wasm-fmt/shfmt": "0.2.7",
    "@x2zod/cli": "workspace:*",
    "@x2zod/tsconfig": "workspace:*",
    "jsr": "0.14.3",
    "markdownlint": "0.41.0",
    "markdownlint-cli2": "0.23.0",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "turbo": "2.9.18",
    "zod": "4.4.3"
  },
  "engines": {
    "bun": "1.3.14",
    "node": "24.18.0"
  },
  "packageManager": "bun@1.3.14"
}
