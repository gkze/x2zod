{
  "name": "x2zod-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Schema and IDL to Zod source compiler.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gkze/x2zod.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "turbo run //#format:check:root //#format:check:shell //#format:check:toml //#lint:actions //#lint:markdown //#lint:root //#lint:shell //#lint:toml lint typecheck test",
    "commitlint": "commitlint",
    "format": "turbo run //#format:root //#format:shell //#format:toml",
    "format:check": "turbo run //#format:check:root //#format:check:shell //#format:check:toml",
    "format:check:root": "oxfmt --check .",
    "format:check:shell": "bun scripts/shfmt.ts",
    "format:check:toml": "taplo fmt --check prek.toml",
    "format:root": "oxfmt --write .",
    "format:shell": "bun scripts/shfmt.ts --write",
    "format:toml": "taplo fmt prek.toml",
    "hooks:install": "prek install --hook-type pre-commit --hook-type commit-msg --hook-type pre-push --overwrite",
    "hooks:run": "prek run --all-files",
    "lint": "turbo run //#lint:actions //#lint:markdown //#lint:root //#lint:shell //#lint:toml lint",
    "lint:actions": "github-actionlint .github/workflows/*.yml",
    "lint:fix": "bun run oxlint --fix .",
    "lint:markdown": "markdownlint-cli2",
    "lint:root": "bun run oxlint .markdownlint-cli2.mjs commitlint.config.ts scripts",
    "lint:shell": "${SHELLCHECK_BINARY:-shellcheck} .envrc",
    "lint:toml": "taplo lint prek.toml",
    "oxlint": "bunx oxlint",
    "publish:jsr": "bun scripts/publish-packages.ts jsr",
    "publish:npm": "bun scripts/publish-packages.ts npm",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "x2zod": "x2zod"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/types": "21.0.1",
    "@j178/prek": "0.4.2",
    "@optique/core": "1.0.2",
    "@optique/run": "1.0.2",
    "@taplo/cli": "0.7.0",
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@wasm-fmt/shfmt": "0.2.7",
    "@x2zod/cli": "workspace:*",
    "github-actionlint": "1.7.12",
    "jsr": "0.14.3",
    "markdownlint": "0.40.0",
    "markdownlint-cli2": "0.22.1",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "shellcheck": "4.1.0",
    "tsconfig": "workspace:*",
    "turbo": "2.9.6"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
