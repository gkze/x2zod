{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["bun.lock"],
  "tasks": {
    "//#format:check": {
      "inputs": [
        "$TURBO_ROOT$/.github/workflows/**/*.yaml",
        "$TURBO_ROOT$/.github/workflows/**/*.yml",
        "$TURBO_ROOT$/.oxfmtrc.json",
        "$TURBO_ROOT$/.markdownlint-cli2.mjs",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_ROOT$/.zed/**/*.json",
        "$TURBO_ROOT$/AGENTS.md",
        "$TURBO_ROOT$/README.md",
        "$TURBO_ROOT$/apps/**/*.json",
        "$TURBO_ROOT$/apps/**/*.ts",
        "$TURBO_ROOT$/commitlint.config.ts",
        "$TURBO_ROOT$/docs/**/*.md",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/packages/**/*.json",
        "$TURBO_ROOT$/packages/**/*.ts",
        "$TURBO_ROOT$/prek.toml",
        "$TURBO_ROOT$/scripts/**/*.ts",
        "$TURBO_ROOT$/tsconfig*.json",
        "$TURBO_ROOT$/turbo.json"
      ],
      "outputs": []
    },
    "//#actions:lint": {
      "inputs": [
        "$TURBO_ROOT$/.github/workflows/**/*.yaml",
        "$TURBO_ROOT$/.github/workflows/**/*.yml",
        "$TURBO_ROOT$/package.json"
      ],
      "outputs": []
    },
    "//#lint:root": {
      "inputs": [
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/tsconfig.configs.json",
        "$TURBO_ROOT$/packages/tsconfig/base.json",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_ROOT$/.markdownlint-cli2.mjs",
        "$TURBO_ROOT$/scripts/**/*.ts"
      ],
      "outputs": []
    },
    "//#markdown:lint": {
      "inputs": [
        "$TURBO_ROOT$/.markdownlint-cli2.mjs",
        "$TURBO_ROOT$/**/*.md",
        "!$TURBO_ROOT$/node_modules/**",
        "!$TURBO_ROOT$/**/.turbo/**"
      ],
      "outputs": []
    },
    "//#shell:format:check": {
      "inputs": [
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/.envrc",
        "$TURBO_ROOT$/scripts/shfmt.ts"
      ],
      "outputs": []
    },
    "//#shell:lint": { "inputs": ["$TURBO_ROOT$/.envrc"], "outputs": [] },
    "//#toml:check": { "inputs": ["$TURBO_ROOT$/prek.toml"], "outputs": [] },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/.oxlintrc.json",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/packages/tsconfig/base.json"
      ],
      "outputs": []
    },
    "test": { "dependsOn": ["^test"], "inputs": ["$TURBO_DEFAULT$"], "outputs": [] },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/packages/tsconfig/base.json"
      ],
      "outputs": []
    }
  }
}
