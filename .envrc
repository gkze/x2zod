# vi: ft=bash
# shellcheck shell=bash source=/dev/null

if ! has nix_direnv_version || ! nix_direnv_version 3.1.1; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.1/direnvrc" "sha256-p+fzQdrms/hDa7g+soShAybJNo4bN4SIAeSfqNKgD5I="
fi

watch_file flake.nix
watch_file flake.lock
watch_file bun.lock
watch_file package.json
watch_file apps/cli/package.json
watch_file packages/core/package.json
watch_file packages/json-schema/package.json

if ! use flake .; then
  echo "direnv: nix flake failed to load. Fix flake.nix and press Enter to retry." >&2
fi

PATH_add node_modules/.bin

source_env_if_exists "${PWD}/.envrc.local"
