{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "nursery": "error",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error",
  },
  "env": { "builtin": true, "node": true },
  "ignorePatterns": [
    ".dex/**",
    ".direnv/**",
    ".publish-tmp/**",
    ".turbo/**",
    "**/.cache/**",
    "**/.tmp-x2zod-*/**",
    "**/node_modules/**",
    "coverage/**",
    "dist/**",
    "packages/*/src/generated/**",
    "packages/core/src/targets/**/generated/**",
    "src/targets/**/generated/**",
  ],
  "options": {
    "denyWarnings": true,
    "maxWarnings": 0,
    "reportUnusedDisableDirectives": "error",
    "respectEslintDisableDirectives": false,
    "typeAware": true,
    "typeCheck": true,
  },
  "jsPlugins": ["./packages/eslint-plugins/src/index.ts"],
  "plugins": ["eslint", "import", "jsdoc", "node", "oxc", "promise", "typescript", "unicorn"],
  "rules": {
    "curly": ["error", "multi"],
    // Export placement is presentation-only; inline exported declarations keep APIs near implementation.
    "exports-last": "off",
    // Export grouping is presentation-only; inline named exports are clearer for typed library APIs.
    "group-exports": "off",
    "id-length": ["error", { "exceptionPatterns": ["^T[A-Z]"], "exceptions": ["T", "z"] }],
    "no-magic-numbers": [
      "error",
      {
        "ignore": [0, 1, 2],
        "ignoreArrayIndexes": true,
        "ignoreDefaultValues": true,
        "ignoreEnums": true,
        "ignoreNumericLiteralTypes": true,
        "ignoreReadonlyClassProperties": true,
      },
    ],
    "max-lines-per-function": [
      "error",
      { "max": 100, "skipBlankLines": true, "skipComments": true },
    ],
    "max-statements": ["error", 40],
    "max-lines": ["error", 500],
    "max-dependencies": ["error", { "max": 20 }],
    "extensions": [
      "error",
      "ignorePackages",
      {
        "checkTypeImports": true,
        "cjs": "never",
        "cts": "never",
        "js": "never",
        "jsx": "never",
        "mjs": "never",
        "mts": "never",
        "ts": "never",
        "tsx": "never",
      },
    ],
    // Named exports are the TypeScript library default; they preserve canonical names and auto-imports.
    "no-default-export": "error",
    // Named exports are the TypeScript library default; do not force default-only module APIs.
    "no-named-export": "off",
    // JSON Schema and generated Zod plans need null as a first-class literal, not a banned sentinel.
    "no-null": "off",
    // Async APIs are real package/script boundaries here; banning async/await would obscure control flow.
    "no-async-await": "off",
    "no-console": "error",
    "no-duplicate-imports": ["error", { "allowSeparateTypeImports": true }],
    // CLI, publish scripts, and the Oxlint plugin legitimately use Node built-ins.
    "no-nodejs-modules": "off",
    // Optional chaining keeps nullable/schema-tree traversal direct and type-safe.
    "no-optional-chaining": "off",
    // Package tests intentionally reach nearby source with relative imports until public package self-imports are warranted.
    "no-relative-parent-imports": "off",
    // Object and array spread are idiomatic for immutable IR updates and option construction.
    "no-rest-spread-properties": "off",
    // Ternaries keep compact expression builders readable and match the repo's expression-return style.
    "no-ternary": "off",
    // Explicit undefined checks are clearer than sentinel rewrites around TypeScript/native-preview APIs.
    "no-undefined": "off",
    "no-unsafe-type-assertion": "error",
    "no-use-before-define": "error",
    // Single-export modules should still use named exports for stable refactors and package APIs.
    "prefer-default-export": "off",
    // External callback types make readonly parameter checking noisy beyond the repo's own typed IRs.
    "prefer-readonly-parameter-types": "off",
    // oxfmt/import grouping already owns import order; this rule creates duplicate style churn.
    "sort-imports": "off",
    // Object key order often encodes schema/source emission order, so sorting keys would reduce readability.
    "sort-keys": "off",
    "x2zod/compact-arrow-returns": "error",
    "x2zod/compact-control-statements": "error",
    "x2zod/const-arrow-functions": "error",
    "x2zod/split-long-strings": "error",
  },
  "settings": {
    "jsdoc": {
      "augmentsExtendsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "ignoreInternal": false,
      "ignorePrivate": false,
      "ignoreReplacesDocs": false,
      "implementsReplacesDocs": false,
      "overrideReplacesDocs": false,
      "tagNamePreference": {},
    },
  },
  "overrides": [
    {
      "files": ["packages/core/src/**/*.ts", "packages/input-json-schema/src/**/*.ts"],
      "rules": {
        // Published library source should stay runtime-neutral; hosts, tests, and scripts own Node adapters.
        "no-nodejs-modules": "error",
      },
    },
    {
      "files": ["apps/cli/src/cli.ts"],
      "rules": {
        // The CLI entrypoint is the only place allowed to write user-facing process output.
        "no-console": "off",
      },
    },
    {
      "files": ["packages/config/src/code-quality.ts", "scripts/publish.ts"],
      "rules": {
        // These loops intentionally serialize transforms and registry publishes.
        "no-await-in-loop": "off",
      },
    },
    {
      "files": ["packages/input-json-schema/src/constraints.ts"],
      "rules": {
        // JSON Schema regex patterns do not imply JavaScript's Unicode flag.
        "require-unicode-regexp": "off",
      },
    },
    {
      "files": [
        "scripts/check-native-tools.ts",
        "scripts/check-runtime-versions.ts",
        "test/native-source-harness.ts",
      ],
      "rules": {
        // Native tool and runtime paths are explicit host inputs supplied by Nix and CI.
        "node/no-process-env": "off",
      },
    },
    {
      "files": ["packages/config/test/config.test.ts"],
      "rules": {
        // Runtime validation tests intentionally pass statically invalid fixtures through public APIs.
        "typescript/no-unnecessary-type-assertion": "off",
      },
    },
    {
      "files": [
        "apps/cli/src/cli.ts",
        "apps/cli/test/zod-to-optique.test.ts",
        "packages/config/src/code-quality.ts",
        "packages/config/src/compile.ts",
        "packages/config/src/load.ts",
        "packages/config/src/zod-cli-metadata.ts",
        "packages/config/src/zod-introspection.ts",
        "packages/config/src/zod-to-optique.ts",
        "packages/config/test/config.test.ts",
        "packages/core/src/diagnostics.ts",
        "packages/core/src/source.ts",
        "packages/core/src/typescript-identifiers.ts",
        "packages/core/src/zod-plan.ts",
        "packages/core/test/source.test.ts",
        "packages/input-json-schema/src/options.ts",
        "packages/input-json-schema/src/reference.ts",
        "scripts/changeset-required.ts",
        "scripts/publish.test.ts",
      ],
      "rules": {
        // Branded values, deliberately invalid fixtures, and third-party generic boundaries require
        // checked narrowing helpers that TypeScript represents as assertions.
        "no-unsafe-type-assertion": "off",
      },
    },
    {
      "files": [
        "apps/cli/src/cli.ts",
        "packages/build-inputs/src/archive-materialization.ts",
        "packages/build-inputs/src/lockfile.ts",
        "packages/config/src/errors.ts",
        "packages/config/src/load.ts",
        "packages/config/src/zod-cli-errors.ts",
        "packages/config/src/zod-cli-metadata.ts",
        "packages/config/src/zod-introspection.ts",
        "packages/config/src/zod-to-optique.ts",
        "packages/core/src/source.ts",
        "packages/core/src/typescript-identifiers.ts",
        "packages/core/src/zod-plan-metadata.ts",
        "packages/core/src/zod-plan-receiver-validation.ts",
        "packages/core/src/zod-plan-validation.ts",
        "packages/core/src/zod-plan.ts",
        "packages/input-json-schema/src/keyword-diagnostics.ts",
        "packages/input-json-schema/src/lower.ts",
        "packages/input-json-schema/src/unevaluated-properties.ts",
        "packages/input-json-schema/test/plugin.test.ts",
      ],
      "rules": {
        // These modules intentionally declare recursive or dependency-ordered const-arrow graphs.
        "no-use-before-define": "off",
      },
    },
    {
      "files": [
        ".markdownlint-cli2.mjs",
        "commitlint.config.ts",
        "packages/eslint-plugins/src/index.ts",
      ],
      "rules": {
        // These config/plugin entrypoints need default exports because their consumers load default exports.
        "no-default-export": "off",
      },
    },
    {
      "files": [
        "packages/build-inputs/src/archive-materialization.ts",
        "packages/build-inputs/src/build-inputs.ts",
        "packages/build-inputs/src/lockfile.ts",
        "packages/build-inputs/src/schemas.ts",
        "packages/config/src/load.ts",
      ],
      "rules": {
        // This package is intentionally a filesystem/archive state machine; the remaining rules are
        // noisy around ordered writes, archive mode bits, byte signatures, and callback-only libraries.
        "max-lines": "off",
        "max-params": "off",
        "no-await-in-loop": "off",
        "no-bitwise": "off",
        "no-continue": "off",
        "no-magic-numbers": "off",
        "no-nested-ternary": "off",
        "unicorn/no-nested-ternary": "off",
        "no-void": "off",
        "avoid-new": "off",
        "import/no-namespace": "off",
        "no-array-callback-reference": "off",
        "no-array-sort": "off",
        "numeric-separators-style": "off",
        "number-literal-case": "off",
        "prefer-await-to-callbacks": "off",
        "prefer-await-to-then": "off",
        "promise-function-async": "off",
        "typescript/promise-function-async": "off",
        "typescript/triple-slash-reference": "off",
      },
    },
    {
      "files": ["**/*.test.ts"],
      "rules": {
        // node:test registration returns promises; test files use void to mark those registrations as intentional.
        "no-void": "off",
      },
    },
    {
      "files": ["packages/build-inputs/src/directory-merkle-tree.ts"],
      "rules": {
        // The Merkle walker depends on deterministic ordered traversal and POSIX executable bits.
        "no-await-in-loop": "off",
        "no-bitwise": "off",
        "no-continue": "off",
        "no-magic-numbers": "off",
        "promise-function-async": "off",
        "typescript/promise-function-async": "off",
      },
    },
    {
      "files": ["packages/build-inputs/src/tar-v6.d.ts"],
      "rules": {
        // Ambient declaration files are intentionally script-shaped.
        "import/unambiguous": "off",
      },
    },
    {
      "files": ["packages/build-inputs/src/**/*.test.ts"],
      "rules": {
        // These tests encode fixture sizes, file modes, and Bun expect async matchers.
        "import/no-namespace": "off",
        "max-lines-per-function": "off",
        "no-await-expression-member": "off",
        "no-magic-numbers": "off",
        "no-namespace": "off",
        "require-await": "off",
        "await-thenable": "off",
        "no-confusing-void-expression": "off",
        "prefer-response-static-json": "off",
        "typescript/await-thenable": "off",
        "typescript/no-confusing-void-expression": "off",
        "typescript/require-await": "off",
      },
    },
  ],
}
